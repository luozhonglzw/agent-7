# ═══════════════════════════════════════════════════════════════
# RAG Knowledge Base System - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values

# ── Application ───────────────────────────────────────────────
APP_NAME=RAG-KB-System
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_2024
POSTGRES_DB=rag_kb

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=rag_documents
QDRANT_API_KEY=

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Celery ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM Configuration ────────────────────────────────────────
LLM_BASE_URL=https://api.xiaomimimo.com/anthropic
LLM_API_KEY=your_api_key_here
LLM_MODEL=mimo-v2-pro
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_STREAM=true

# ── Embedding Model ───────────────────────────────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_LENGTH=8192

# ── Reranker Model ───────────────────────────────────────────
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=32
RERANKER_MAX_LENGTH=8192

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.md,.txt,.pptx,.ppt

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Admin Bootstrap ───────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_USERNAME=admin
